{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2021",
    "lib": ["dom", "es2015"],
    "rootDir": ".",
    "outDir": "../out",
    "sourceMap": true,
    "removeComments": true,
    "strict": true,
    "jsx": "react-native",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "browser/*": ["../../../src/browser/*"],
      "@xterm/addon-react-native": ["../typings/addon-react-native.d.ts"],
      "@xterm/xterm": ["../../../typings/xterm.d.ts"]
    }
  },
  "include": ["./**/*", "../../../typings/xterm.d.ts"],
  "references": [{ "path": "../../../src/browser" }]
}
